<Window x:Class="WinTunePro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinTune Pro" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="WinTune Pro - Native Prototype" FontSize="20" FontWeight="Bold" />
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">
            <Button Name="BtnScan" Width="200" Height="40" Margin="0,4" Click="BtnScan_Click">Run Scan (TestMode)</Button>
            <Button Name="BtnClean" Width="200" Height="40" Margin="0,4" Click="BtnClean_Click">Run Clean (TestMode)</Button>
            <Button Name="BtnOptimize" Width="200" Height="40" Margin="0,4" Click="BtnOptimize_Click">Optimize (TestMode)</Button>
            <TextBox Name="Output" Height="300" Margin="0,10,0,0" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" />
        </StackPanel>
    </Grid>
</Window>
